# Server (copy to server/.env)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_RESOLVE=gpt-4o-mini
PORT=4000
CORS_ORIGIN=http://localhost:3000
# Server logs: trace | debug | info | warn | error (default: debug in dev, info in prod)
LOG_LEVEL=debug

# mysql2 accepts a connection URI:
DATABASE_URL=mysql://user:password@127.0.0.1:3306/competitor_analyzer

# Web (copy to web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:4000
